{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "super-clipboard",
  "version": "1.0.1",
  "identifier": "app.superclipboard.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:frontend",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "super-clipboard",
        "width": 900,
        "height": 680,
        "minWidth": 760,
        "minHeight": 560,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZBQjIxRjAyMjcyOTA4NjgKUldSb0NDa25BaCt5K29JbU1xRjhlS0l6M0ZDejcrUmdyRDJuVFdxN1dNTHFHVDloQ0NBaEpDbFgK",
      "endpoints": [
        "https://github.com/qianduoduo184/super-clipboard/releases/latest/download/latest.json"
      ]
    }
  }
}
